# Optional NCBI metadata enrichment
ENTREZ_EMAIL=you@example.com
NCBI_API_KEY=

# AI summaries default to a local Ollama instance.
AI_SUMMARY_PROVIDER=ollama
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=gemma3:4b

# To use an AWS Bedrock API Gateway instead, set these locally and never
# commit the real values.
# AI_SUMMARY_PROVIDER=bedrock
# BEDROCK_API_URL=https://your-api-id.execute-api.your-region.amazonaws.com/your-stage/query
# BEDROCK_API_KEY=

# Web server. Defaults are loopback-only with the debugger off; override only
# if you need to. DASH_DEBUG enables the Werkzeug console, which executes
# arbitrary code for anyone who can reach the port, so it is refused on any
# host other than loopback.
DASH_HOST=127.0.0.1
DASH_PORT=8050
DASH_DEBUG=0
